---
import dayjs from "dayjs";
import BaseLayout from "./baseLayout.astro";

export interface Props {
  frontmatter: {
    title: string;
    subtitle: string;
    description: string;
    pubDate: string;
    image: {
      src: string;
      width: number;
      height: number;
      format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
    };
    link: string;
    source: string;
    tags: string[];
  };
}

const {
  frontmatter: { title, subtitle, description, pubDate, image, link, source },
} = Astro.props;

const formatedDate = dayjs(pubDate).format("MMMM DD, YYYY");
const projectLink = link || source;
const hasDistinctSource = Boolean(source && source !== projectLink);
const siteUrl = Astro.site ?? new URL("https://nstlopez.com");
const personId = new URL("#person", siteUrl).href;
const organizationId = new URL("#organization", siteUrl).href;
const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": `${Astro.url.href}#software`,
  name: title,
  description,
  url: projectLink || Astro.url.href,
  image: new URL(image.src, siteUrl).toString(),
  datePublished: new Date(pubDate).toISOString(),
  author: {
    "@type": "Person",
    "@id": personId,
    name: "Néstor López",
    url: siteUrl.toString(),
  },
  publisher: { "@id": organizationId },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={image.src}
  jsonLd={[softwareJsonLd]}
>
  <div class="mt-10">
    <a
      href="/projects"
      class="text-cool-grey-800 dark:text-mono-100 inline-flex items-center gap-2 hover:underline"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Go Back
    </a>
  </div>
  <article
    class="prose prose-slate dark:prose-invert lg:prose-xl prose-a:text-cool-grey-800 prose-a:no-underline prose-a:hover:underline dark:prose-a:text-mono-100 mt-6 max-w-none"
  >
    <h1>{title}</h1>
    <p class="text-cool-grey-700 dark:text-cool-grey-300 -mt-4 text-lg">
      {subtitle}
    </p>
    <div class="flex justify-between">
      <span>
        <time>{formatedDate}</time>
      </span>
    </div>
    <img
      class="w-full object-cover shadow-lg"
      src={image.src}
      alt={title}
      fetchpriority="high"
      loading="eager"
    />
    <div class="flex flex-wrap gap-4">
      <a
        target="_blank"
        rel="noreferrer"
        href={projectLink}
        data-s:event="project_link_view"
        data-s:event-props={`title=${title}`}
      >
        View project
      </a>
      {
        hasDistinctSource && (
          <a
            target="_blank"
            rel="noreferrer"
            href={source}
            data-s:event="project_source_view"
            data-s:event-props={`title=${title}`}
          >
            View source
          </a>
        )
      }
    </div>
    <slot />
  </article>
</BaseLayout>

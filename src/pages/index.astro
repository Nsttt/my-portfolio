---
import { getCollection } from "astro:content";
import ContentCard from "../components/contentCard.astro";
import BaseLayout from "../layouts/baseLayout.astro";

const posts = await getCollection("posts");
const projects = await getCollection("projects");
const talks = await getCollection("talks");
---

<BaseLayout
  title="Néstor's Blog"
  description="Writing about software architecture, distributed systems, Module Federation, and developer tooling."
>
  <section class="mt-20 flex">
    <div class="w-full text-xl">
      <h1 class="mb-10 text-3xl">Hi 👋, I'm Néstor, from Spain 🇪🇸</h1>
      <p class="my-3">
        I'm a Software Engineer building typesafe, scalable systems. Currently
        working on Module Federation, edge-native deployments, and weird
        infrastructure ideas at <a
          class="text-cool-grey-800 dark:text-mono-300 underline"
          href="https://zephyr-cloud.io/"
          target="_blank">Zephyr Cloud</a
        >.
      </p>
      <p class="my-3">I contribute to several open source projects:</p>
      <ul class="my-3 ml-6 list-disc space-y-2">
        <li>
          <a
            class="text-cool-grey-800 dark:text-mono-300 underline"
            href="https://trpc.io/"
            target="_blank"
            data-s:event="oss_trpc"
            data-s:event-props="category=framework">tRPC</a
          > - A framework for building typesafe APIs with TypeScript
        </li>
        <li>
          <a
            class="text-cool-grey-800 dark:text-mono-300 underline"
            href="https://create.t3.gg/"
            target="_blank"
            data-s:event="oss_t3"
            data-s:event-props="category=template">T3 Stack</a
          > - A fullstack Next.js template for typesafe applications
        </li>
        <li>
          <a
            class="text-cool-grey-800 dark:text-mono-300 underline"
            href="https://module-federation.io/"
            target="_blank"
            data-s:event="oss_module_federation"
            data-s:event-props="category=architecture">Module Federation</a
          > - Helping teams build scalable micro-frontend architectures
        </li>
      </ul>
      <p class="my-3">
        I also do <a
          class="text-cool-grey-800 dark:text-mono-300 underline"
          href="/talks">conference talks and workshops</a
        > about Module Federation, infrastructure, OSS tools, IoT, and systems design.
      </p>
      <p class="my-3">
        Finally, I am part of <a
          class="text-cool-grey-800 dark:text-mono-300 underline"
          href="https://industry40.systems/"
          target="_blank"
          data-s:event="oss_industry40"
          data-s:event-props="category=research">I40sys</a
        >, a research group focused on Industry 4.0 and digital transformation.
        I also help people and teams through consulting and mentoring.
      </p>
    </div>
  </section>
  <section>
    <div
      class="border-cool-grey-400 dark:border-cool-grey-700 mt-28 mb-10 flex justify-between border-b-[1px] pb-5"
    >
      <h2 class="self-baseline text-4xl">Latest posts</h2>
      <a
        href="/blog"
        class="text-cool-grey-800 dark:text-mono-300 self-baseline text-lg underline"
        data-s:event="view_all_posts">See all posts</a
      >
    </div>
    <ul class="flex flex-col gap-x-2 gap-y-8 sm:gap-x-4 xl:gap-x-6">
      {
        posts
          .filter((post) => !post.data.draft)
          .sort(
            (a, b) =>
              new Date(b.data.pubDate).valueOf() -
              new Date(a.data.pubDate).valueOf(),
          )
          .slice(0, 3)
          .map((post) => (
            <li>
              <ContentCard
                href={`/blog/${post.id}/`}
                title={post.data.title}
                description={post.data.description}
                date={post.data.pubDate}
                eyebrow="Post"
                expectedReadTime={post.data.expectedReadTime}
                tags={post.data.tags}
                eventName="blog_post_click"
                eventProps={`title=${post.data.title}`}
              />
            </li>
          ))
      }
    </ul>
  </section>
  <section>
    <div
      class="border-cool-grey-400 dark:border-cool-grey-700 mt-20 mb-10 flex justify-between border-b-[1px] pb-5"
    >
      <h2 class="self-baseline text-4xl">Talks and Workshops</h2>
      <a
        href="/talks"
        class="text-cool-grey-800 dark:text-mono-300 self-baseline text-lg underline"
        data-s:event="view_all_talks">See all content</a
      >
    </div>
    <ul class="flex flex-col gap-5">
      {
        talks
          .sort(
            (a, b) =>
              new Date(b.data.pubDate).valueOf() -
              new Date(a.data.pubDate).valueOf(),
          )
          .slice(0, 3)
          .map((talk) => (
            <li>
              <ContentCard
                href={`/talks/${talk.id}/`}
                title={talk.data.title}
                description={talk.data.description}
                date={talk.data.pubDate}
                eyebrow={
                  {
                    conference: "Conference",
                    meetup: "Meetup",
                    workshop: "Workshop",
                    podcast: "Podcast / Radio",
                    campus: "Campus Session",
                  }[talk.data.category]
                }
                primaryMeta={talk.data.place}
                secondaryMeta={talk.data.lang}
                accent={talk.data.category}
                tags={talk.data.tags}
                eventName="talk_click"
                eventProps={`title=${talk.data.title}`}
              />
            </li>
          ))
      }
    </ul>
  </section>
  <section>
    <div
      class="border-cool-grey-400 dark:border-cool-grey-700 mt-20 mb-10 flex justify-between border-b-[1px] pb-5"
    >
      <h2 class="self-baseline text-4xl">Things I've built</h2>
      <a
        href="/projects"
        class="text-cool-grey-800 dark:text-mono-300 self-baseline text-lg underline"
        data-s:event="view_all_projects">See all projects</a
      >
    </div>
    <ul class="flex flex-col gap-x-2 gap-y-8 sm:gap-x-4 xl:gap-x-6">
      {
        projects
          .sort(
            (a, b) =>
              new Date(b.data.pubDate).valueOf() -
              new Date(a.data.pubDate).valueOf(),
          )
          .slice(0, 3)
          .map((project) => (
            <li>
              <ContentCard
                href={`/projects/${project.id}/`}
                title={project.data.title}
                description={project.data.description}
                date={project.data.pubDate}
                eyebrow="Project"
                tags={project.data.tags}
                eventName="project_click"
                eventProps={`title=${project.data.title}`}
              />
            </li>
          ))
      }
    </ul>
  </section>
</BaseLayout>

---
import "../styles/base.css";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string | undefined;
  description?: string | undefined;
  image?: string | undefined;
  jsonLd?: Record<string, unknown>[] | undefined;
}
const {
  title,
  description,
  image = "https://nstlopez.com/logo.svg",
  jsonLd = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://nstlopez.com");
const pageUrl = Astro.url.href;
const pageTitle = title ? `${title} | Néstor's Blog` : "Néstor's Blog";
const pageDescription =
  description ??
  "Néstor López writes about software architecture, distributed systems, Module Federation, and developer tooling.";
const modifiedAt = new Date().toISOString();
const globalJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteUrl}#person`,
    name: "Néstor López",
    alternateName: "nstlopez",
    url: siteUrl.toString(),
    image: new URL("/images/profile.webp", siteUrl).toString(),
    jobTitle: "Software Engineer",
    sameAs: [
      "https://x.com/nstlopez",
      "https://github.com/nsttt",
      "https://linkedin.com/in/nstlopez",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}#website`,
    name: "Néstor's Blog",
    url: siteUrl.toString(),
    author: { "@id": `${siteUrl}#person` },
    publisher: { "@id": `${siteUrl}#person` },
    dateModified: modifiedAt,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    isPartOf: { "@id": `${siteUrl}#website` },
    author: { "@id": `${siteUrl}#person` },
    dateModified: modifiedAt,
  },
  ...jsonLd,
];
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content="Néstor López" />
<script
  is:inline
  data-astro-rerun
  defer
  src="https://analytics.nstlopez.com/kebab-de-pollo"
  data-website-id="13fd83d3-ccd7-4995-b8e6-2eef859b99c0"></script>

<!-- Primary Meta Tags -->
<title>{title ? `${title} | Néstor's Blog` : "Néstor's Blog"}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Néstor's Blog" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image} />

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="Néstor's Blog"
  href={new URL("rss.xml", Astro.site)}
/>

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Link Tags -->
<link
  rel="preload"
  href="/fonts/Satoshi-Variable.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/hack-regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />

<ClientRouter />

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(globalJsonLd)}
/>

{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "test": "jest --coverage --watchAll"
  },
  "dependencies": {
    "@apollo/client": "^3.3.6",
    "@mailchimp/mailchimp_marketing": "^3.0.41",
    "@sendgrid/mail": "^7.4.2",
    "graphql": "^15.4.0",
    "marked": "^2.0.0",
    "next": "10.0.5",
    "next-i18next": "^8.2.0",
    "next-seo": "^4.17.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "styled-components": "^5.2.1",
    "styled-normalize": "^8.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.12.0",
    "@testing-library/react": "^11.2.7",
    "babel-jest": "^27.0.2",
    "babel-plugin-styled-components": "^1.12.0",
    "eslint": "^7.19.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^7.2.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "jest": "^27.0.3",
    "prettier": "^2.2.1"
  },
  "jest": {
    "collectCoverageFrom": [
      "!<rootDir>/pages",
      "!<rootDir>/components",
      "!<rootDir>/containers",
      "!<rootDir>/services"
    ],
    "coveragePathIgnorePatterns": [
      "package.json",
      "node_modules",
      ".next",
      "coverage",
      "styles",
      "/components/*/styles",
      "/components/index.js",
      "/public"
    ],
    "testPathIgnorePatterns": [
      "/.next/",
      "/node_modules/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "coverageReporters": [
      "html",
      "text"
    ]
  }
}
